<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================================
     UPDATED CRIS LAYOUT CONFIGURATION - HOME PAGE INFOGRAPHICS
     Changes:
     1. Combines Masters and PhD theses into single "Theses & Dissertations" counter with graduation-cap icon
     2. Changes Scholarly Publications icon to paper/article (fa-file-alt)
     3. Maintains Datasets and Profiles counters
     ============================================================================ -->

<beans xmlns="http://www.springframework.org/schema/beans"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://www.springframework.org/schema/beans
   http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <!-- HOME PAGE CRIS LAYOUT CONFIGURATION -->
    <bean id="sectionsite" class="org.dspace.layout.service.impl.CrisLayoutSectionServiceImpl">
        <property name="layout">
            <bean class="org.dspace.layout.CrisLayoutSection">
                <!-- Section Configuration -->
                <property name="id" value="site"/>
                <property name="componentRows">
                    <list>
                        <!-- ROW 1: COUNTERS/INFOGRAPHICS -->
                        <!-- This row displays statistics counters for main content types -->
                        <bean class="org.dspace.layout.CrisLayoutRow">
                            <property name="cells">
                                <list>
                                    <!-- CELL 1: Counter Component (spans 12 columns on mobile, 6 on tablet, 3 on desktop) -->
                                    <bean class="org.dspace.layout.CrisLayoutCell">
                                        <property name="style" value="col-12 col-md-6 col-lg-3"/>
                                        <property name="component">
                                            <bean class="org.dspace.layout.CrisLayoutCountersComponent">
                                                <!-- Counter Settings List: Each bean represents one counter widget -->
                                                <property name="counterSettingsList">
                                                    <list>
                                                        <!-- Counter 1: Scholarly Publications -->
                                                        <!-- Combines Books, Book Chapters, and Articles -->
                                                        <!-- Icon: paper/article (represents scholarly publications) -->
                                                        <!-- Discovery Query: Uses researchoutputs config to count all publication items -->
                                                        <bean class="org.dspace.layout.CrisLayoutCountersComponent.CounterSettings">
                                                            <property name="discoveryConfigurationName" value="researchoutputs"/>
                                                            <property name="label" value="Scholarly Publications"/>
                                                            <property name="icon" value="fas fa-file-alt fa-3x"/>
                                                            <property name="link" value="/explore/researchoutputs"/>
                                                        </bean>

                                                        <!-- Counter 2: Theses & Dissertations (CONSOLIDATED) -->
                                                        <!-- Combines Masters Dissertations and PhD Theses into one counter -->
                                                        <!-- Icon: graduation-cap (represents academic theses and dissertations) -->
                                                        <!-- Discovery Query: Uses theses config with OR logic to count masters_output + phd_output -->
                                                        <bean class="org.dspace.layout.CrisLayoutCountersComponent.CounterSettings">
                                                            <property name="discoveryConfigurationName" value="theses"/>
                                                            <property name="label" value="Theses & Dissertations"/>
                                                            <property name="icon" value="fas fa-graduation-cap fa-3x"/>
                                                            <property name="link" value="/explore/theses"/>
                                                        </bean>

                                                        <!-- Counter 3: Datasets -->
                                                        <!-- Uses discovery configuration "datasets" to count dataset items -->
                                                        <!-- Icon: database (represents data storage and datasets) -->
                                                        <bean class="org.dspace.layout.CrisLayoutCountersComponent.CounterSettings">
                                                            <property name="discoveryConfigurationName" value="datasets"/>
                                                            <property name="label" value="Datasets"/>
                                                            <property name="icon" value="fas fa-database fa-3x"/>
                                                            <property name="link" value="/explore/datasets"/>
                                                        </bean>

                                                        <!-- Counter 4: Profiles (Researcher/Faculty) -->
                                                        <!-- Uses discovery configuration "person" to count researcher profiles -->
                                                        <!-- Icon: users (represents people and researcher profiles) -->
                                                        <bean class="org.dspace.layout.CrisLayoutCountersComponent.CounterSettings">
                                                            <property name="discoveryConfigurationName" value="person"/>
                                                            <property name="label" value="Profiles"/>
                                                            <property name="icon" value="fas fa-users fa-3x"/>
                                                            <property name="link" value="/explore/researcherprofiles"/>
                                                        </bean>
                                                    </list>
                                                </property>
                                            </bean>
                                        </property>
                                    </bean>
                                </list>
                            </property>
                        </bean>

                        <!-- ROW 2: BROWSE COMPONENTS -->
                        <!-- This row can contain browse components for main collections -->
                        <bean class="org.dspace.layout.CrisLayoutRow">
                            <property name="cells">
                                <list>
                                    <bean class="org.dspace.layout.CrisLayoutCell">
                                        <property name="style" value="col-12"/>
                                        <property name="component">
                                            <bean class="org.dspace.layout.CrisLayoutBrowseComponent">
                                                <!-- Browse configuration can be added here -->
                                            </bean>
                                        </property>
                                    </bean>
                                </list>
                            </property>
                        </bean>
                    </list>
                </property>
            </bean>
        </property>
    </bean>

</beans>
